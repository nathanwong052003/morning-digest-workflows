# Core runtime
TIMEZONE_NAME=Asia/Hong_Kong
RUN_ID=
MOCK_MODE=false
OUTPUT_DIR=output

# Google OAuth (required for live mode)
CLIENT_ID=your_google_client_id
CLIENT_SECRET=your_google_client_secret
REFRESH_TOKEN=your_google_refresh_token
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token

# Gmail collection
GMAIL_USER_ID=me
GMAIL_LABEL_IDS=INBOX,IMPORTANT
GMAIL_KEYWORDS=urgent,invoice,meeting
GMAIL_EXCLUDED_LABELS=CATEGORY_PROMOTIONS,CATEGORY_SOCIAL,CATEGORY_FORUM
GMAIL_BLOCKED_SENDERS=newsletters@example.com,marketing@example.com
GMAIL_MAX_THREADS=20

# News collection (Brave Search API)
BRAVE_API_KEY=your_brave_api_key
NEWS_CACHE_PATH=/tmp/morning_digest_news_cache.json
NEWS_CACHE_TTL_SECONDS=43200

# Distribution
DRIVE_FOLDER_ID=your_drive_folder_id
DIGEST_CALENDAR_ID=primary
DIGEST_EVENT_HOUR=8
DIGEST_EVENT_MINUTE=0
DIGEST_EMAIL_TO=user@example.com

# Digest iteration counter — increments by 1 each run, persisted across runs.
DIGEST_COUNTER_PATH=/tmp/morning_digest_counter.json

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_MAX_TOKENS=1500
AI_RETRY_ATTEMPTS=3

# Cost controls
TOKEN_SPEND_PATH=/tmp/morning_digest_token_spend.json
DAILY_TOKEN_WARN_THRESHOLD=50000

# PDF rendering (WeasyPrint)
# Windows only: set to GTK runtime bin path(s), separated by semicolons.
# Example: C:\msys64\ucrt64\bin
WEASYPRINT_DLL_DIRECTORIES=
# Windows optional: explicit standalone WeasyPrint executable path.
WEASYPRINT_WINDOWS_EXE=
# Windows optional: cache folder for standalone WeasyPrint zip extraction.
WEASYPRINT_WINDOWS_CACHE_DIR=
# Windows optional: override standalone WeasyPrint zip URL.
WEASYPRINT_WINDOWS_ZIP_URL=
